            font_size: "11sp"
            text_size: self.width - dp(16), self.height
            halign: "center"
            valign: "middle"
            shorten: True
            shorten_from: "right"
            canvas.before:
                Color:
                    rgba: hx(app.theme_state.success_soft) if root.status_tone == "success" else hx(app.theme_state.warning_soft)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]
    Label:
        text: root.category_text
        color: hx(app.theme_state.secondary)
        size_hint_y: None
        height: dp(20)
        text_size: self.width, dp(20)
        halign: "left"
        valign: "middle"
        shorten: True
        shorten_from: "right"
    Label:
        text: root.participant_count_text
        color: hx(app.theme_state.muted)
        size_hint_y: None
        height: dp(20)
        text_size: self.width, dp(20)
        halign: "left"
        valign: "middle"
    Label:
        text: root.participants_text
        color: hx(app.theme_state.text_secondary)
        font_size: ds.FONT_LABEL
        size_hint_y: None
        height: dp(34)
        text_size: self.width, dp(34)
        halign: "left"
