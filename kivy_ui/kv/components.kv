            Color:
                rgba: hx(app.theme_state.border)
            Rectangle:
                pos: self.pos
                size: self.size
    BoxLayout:
        size_hint_y: None
        height: dp(42)
        spacing: dp(10)
        SecondaryButton:
            text: "Editar"
            on_release: root.handle_edit()
        DangerButton:
            text: "Eliminar"
            on_release: root.handle_delete()
