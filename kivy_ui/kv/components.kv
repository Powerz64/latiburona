            text_size: self.width, self.height
            halign: "right"
            valign: "middle"
    BoxLayout:
        id: live_rows
        orientation: "vertical"
        spacing: dp(10)
        size_hint_y: None
        height: self.minimum_height

<KpiCard>:
    size_hint_y: None
    height: dp(120)
    padding: ds.SPACE_MD
    spacing: ds.SPACE_XS
    shadow_offset: dp(2)
    BoxLayout:
        size_hint_y: None
        height: dp(28)
        spacing: dp(8)
        Widget:
            size_hint_x: None
            width: dp(12)
            canvas:
                Color:
                    rgba: root.accent_color
                RoundedRectangle:
                    pos: self.center_x - dp(4), self.center_y - dp(4)
                    size: dp(8), dp(8)
                    radius: [dp(4)]
        Label:
            text: root.title_text
            font_name: ds.EMOJI_FONT
            color: hx(app.theme_state.secondary)
            font_size: ds.FONT_LABEL
            bold: True
            text_size: self.size
            halign: "left"
            valign: "middle"
            shorten: True
            shorten_from: "right"
        Widget:
        Label:
            text: root.status_text
            size_hint_x: None
            width: min(self.texture_size[0] + dp(20), dp(156))
            color: root.badge_text_color
            font_size: ds.FONT_LABEL
            text_size: self.width - dp(12), self.height
            halign: "center"
            valign: "middle"
            shorten: True
            shorten_from: "right"
            canvas.before:
                Color:
                    rgba: root.badge_color
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]
    Label:
        text: root.value_text
        color: hx(app.theme_state.text)
        font_size: root.value_font_size
        bold: True
        size_hint_y: None
        height: dp(38)
        text_size: self.size
        halign: "left"
        valign: "middle"
    Label:
        text: root.caption_text
        color: hx(app.theme_state.secondary)
        font_size: ds.FONT_LABEL
        opacity: 0.9
        size_hint_y: None
        height: dp(18)
        text_size: self.width, dp(18)
        halign: "left"
        valign: "middle"

<DemandCard>:
    size_hint_y: None
