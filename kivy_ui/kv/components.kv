        valign: "top"

<InsightsCard>:
    size_hint_y: None
    height: dp(132)
    padding: ds.SPACE_MD
    spacing: ds.SPACE_SM
    shadow_offset: dp(2)
    BoxLayout:
        size_hint_y: None
        height: dp(34)
        spacing: dp(10)
        BoxLayout:
            size_hint_x: None
            width: dp(36)
            canvas.before:
                Color:
                    rgba: root.badge_color
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(12)]
            Label:
                text: root.icon_text
                color: root.accent_color
                font_size: "16sp"
                text_size: self.size
                halign: "center"
                valign: "middle"
        BoxLayout:
            orientation: "vertical"
            Label:
                text: root.eyebrow_text
                color: hx(app.theme_state.muted)
                font_size: ds.FONT_LABEL
                size_hint_y: None
                height: dp(14)
                text_size: self.width, dp(16)
                halign: "left"
                valign: "bottom"
            Label:
                text: root.title_text
                color: hx(app.theme_state.text)
                bold: True
                font_size: ds.FONT_BODY
                size_hint_y: None
                height: dp(20)
                text_size: self.width, dp(22)
                halign: "left"
                valign: "top"
        Label:
            text: root.badge_text
            opacity: 1 if root.badge_text else 0
            size_hint_x: None
            width: min(self.texture_size[0] + dp(24), dp(168)) if root.badge_text else 0
            color: root.badge_text_color
            font_size: ds.FONT_LABEL
            text_size: self.width - dp(12), self.height
            halign: "center"
            valign: "middle"
            shorten: True
            shorten_from: "right"
            canvas.before:
                Color:
                    rgba: root.badge_color if root.badge_text else (0, 0, 0, 0)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]
    Widget:
        size_hint_y: None
        height: dp(2)
        canvas:
            Color:
                rgba: root.accent_color
            RoundedRectangle:
                pos: self.x, self.center_y - dp(1)
                size: self.width, dp(2)
                radius: [dp(2)]
    Label:
        text: root.body_text
        color: hx(app.theme_state.secondary)
        font_size: ds.FONT_BODY
        opacity: 0.88
        size_hint_y: None
        height: dp(44)
        text_size: self.width, dp(44)
        halign: "left"
        valign: "top"

<ReservationRow>:
    size_hint_y: None
    orientation: "vertical"
    height: dp(220)
    padding: dp(14)
    spacing: dp(9)
    background_color: hx(app.theme_state.card_alt)
    border_color: hx(app.theme_state.success) if root.status_tone == "success" else hx(app.theme_state.primary)
    shadow_offset: dp(2)
    canvas.before:
        Color:
            rgba: hx(app.theme_state.success_soft) if root.status_tone == "success" else hx(app.theme_state.primary_soft)
        RoundedRectangle:
            pos: self.x + dp(8), self.y + dp(8)
            size: dp(5), self.height - dp(16)
            radius: [dp(3)]
    BoxLayout:
        size_hint_y: None
        height: dp(40)
        spacing: dp(12)
        BoxLayout:
            size_hint_x: None
            width: dp(40)
            canvas.before:
                Color:
                    rgba: hx(app.theme_state.success_soft) if root.status_tone == "success" else hx(app.theme_state.primary_soft)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]
            Label:
                text: "⚽"
                font_name: ds.EMOJI_FONT
                color: hx(app.theme_state.success) if root.status_tone == "success" else hx(app.theme_state.primary)
                font_size: "20sp"
                text_size: self.size
                halign: "center"
                valign: "middle"
        BoxLayout:
            orientation: "vertical"
            spacing: dp(2)
            Label:
                text: root.client_name
                color: hx(app.theme_state.text)
                bold: True
                font_size: "15sp"
                size_hint_y: None
                height: dp(20)
                text_size: self.width, dp(20)
                halign: "left"
                valign: "middle"
                shorten: True
                shorten_from: "right"
            Label:
                text: "Partido " + root.schedule_text
                color: hx(app.theme_state.text_muted)
                font_size: ds.FONT_LABEL
                size_hint_y: None
                height: dp(16)
                text_size: self.width, dp(16)
                halign: "left"
                valign: "middle"
                shorten: True
                shorten_from: "right"
        Label:
            text: root.total_text
            color: hx(app.theme_state.text)
            bold: True
            font_size: "15sp"
            size_hint_x: None
            width: dp(126)
            text_size: self.width, self.height
            halign: "right"
            valign: "middle"
    BoxLayout:
        size_hint_y: None
        height: dp(50)
        spacing: dp(12)
        GridLayout:
            cols: 2
            spacing: dp(8)
            Label:
                text: "📍 " + root.service_type
                font_name: ds.EMOJI_FONT
                color: hx(app.theme_state.secondary)
                font_size: ds.FONT_LABEL
                text_size: self.size
                halign: "left"
                valign: "middle"
                shorten: True
                shorten_from: "right"
            Label:
                text: "🕒 " + root.datetime_text
                font_name: ds.EMOJI_FONT
                color: hx(app.theme_state.secondary)
                font_size: ds.FONT_LABEL
                text_size: self.size
                halign: "left"
                valign: "middle"
                shorten: True
                shorten_from: "right"
            Label:
                text: "👥 " + root.people_text
                font_name: ds.EMOJI_FONT
                color: hx(app.theme_state.muted)
                font_size: ds.FONT_LABEL
                text_size: self.size
                halign: "left"
                valign: "middle"
                shorten: True
                shorten_from: "right"
            Label:
                text: "🏟 " + root.schedule_text
                font_name: ds.EMOJI_FONT
                color: hx(app.theme_state.muted)
                font_size: ds.FONT_LABEL
                text_size: self.size
                halign: "left"
                valign: "middle"
                shorten: True
                shorten_from: "right"
        Label:
            text: root.status_text
            size_hint_x: None
            width: dp(118)
            color: hx(app.theme_state.success) if root.status_tone == "success" else hx(app.theme_state.warning) if root.status_tone == "warning" else hx(app.theme_state.danger)
            font_size: "11sp"
            bold: True
            text_size: self.width - dp(16), self.height
            halign: "center"
            valign: "middle"
            shorten: True
            shorten_from: "right"
            canvas.before:
                Color:
                    rgba: hx(app.theme_state.success_soft) if root.status_tone == "success" else hx(app.theme_state.warning_soft) if root.status_tone == "warning" else hx(app.theme_state.danger_soft)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(16)]
    Widget:
        size_hint_y: None
        height: dp(1)
        canvas:
            Color:
                rgba: hx(app.theme_state.border)
            Rectangle:
                pos: self.pos
                size: self.size
    BoxLayout:
        size_hint_y: None
        height: dp(32)
        spacing: dp(12)
        Label:
            text: root.promo_label_text if root.promo_label_text else root.promotion_text
            color: hx(app.theme_state.text_secondary)
            font_size: "11sp"
            text_size: self.size
            halign: "left"
            valign: "middle"
            shorten: True
            shorten_from: "right"
        InfoPill:
            size_hint_x: None
            width: dp(150)
            text: root.match_badge_text
            background_color: hx(app.theme_state.primary_soft)
            border_color: hx(app.theme_state.primary)
    BoxLayout:
        size_hint_y: None
        height: dp(44)
        padding: dp(6), dp(4)
        spacing: dp(14)
        canvas.before:
            Color:
                rgba: hx(app.theme_state.surface)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(14)]
        BoxLayout:
            size_hint: 1, 1
            size_hint_x: 1 if root.show_management_actions else 0
            spacing: dp(14)
            opacity: 1 if root.show_management_actions else 0
            SecondaryButton:
                text: "Editar"
                disabled: not root.show_management_actions
                on_release: app.get_screen("reservations").on_edit(root.data)
            SuccessButton:
                text: "Confirmar"
                disabled: (not root.show_management_actions) or root.is_confirmed
                on_release: app.get_screen("reservations").on_confirm(root.data)
            DangerButton:
                text: "Eliminar"
                disabled: not root.show_management_actions
                on_release: app.get_screen("reservations").on_delete(root.data)
        BoxLayout:
            size_hint: 1, 1
            size_hint_x: 0 if root.show_management_actions else 1
            spacing: dp(14)
            opacity: 0 if root.show_management_actions else 1
            SecondaryButton:
                text: "Editar"
                disabled: root.show_management_actions
                on_release: app.get_screen("reservations").on_edit(root.data)

<TournamentRow>:
    size_hint_y: None
    height: dp(236)
    padding: dp(16)
    spacing: dp(10)
    background_color: hx(app.theme_state.card_alt)
