#:import dp kivy.metrics.dp
#:import ds kivy_ui.theme
#:import hx kivy.utils.get_color_from_hex

<ReservationsScreen>:
    name: "reservations"

    BoxLayout:
        orientation: "vertical"

        ScrollView:
            do_scroll_x: False
            bar_width: dp(6)

            AnchorLayout:
                anchor_x: "center"
                anchor_y: "top"
                size_hint_y: None
                height: content.height

                BoxLayout:
                    id: content
                    orientation: "vertical"
                    size_hint: None, None
                    width: min(root.width - dp(48), ds.MAX_CONTENT_WIDTH)
                    height: self.minimum_height
                    padding: dp(24)
                    spacing: dp(28)

                    CardBox:
                        size_hint_y: None
                        height: self.minimum_height
                        padding: dp(20)
                        spacing: dp(8)
                        background_color: hx(app.theme_state.surface_alt)
                        border_color: hx(app.theme_state.success)
                        shadow_offset: dp(2)

                        BoxLayout:
                            size_hint_y: None
                            height: dp(30)
                            spacing: dp(10)
                            Label:
                                text: "⚽"
                                font_name: ds.EMOJI_FONT
                                color: hx(app.theme_state.primary)
                                font_size: "22sp"
                                size_hint_x: None
                                width: dp(28)
                                text_size: self.size
                                halign: "center"
                                valign: "middle"
                            Label:
                                text: "Centro de partidos"
                                color: hx(app.theme_state.text_primary)
                                font_size: "26sp"
                                bold: True
                                text_size: self.size
                                halign: "left"
                                valign: "middle"

                        Label:
                            text: "Crea partidos, valida disponibilidad y administra reservas con tarjetas tipo jornada."
                            color: hx(app.theme_state.text_secondary)
                            font_size: ds.FONT_BODY
                            size_hint_y: None
                            height: dp(22)
                            text_size: self.width, dp(22)
                            halign: "left"
                            valign: "middle"

                        Label:
                            text: root.loading_message if root.loading else root.inline_status
                            color: hx(app.theme_state.primary) if root.loading else hx(app.theme_state.text_muted)
                            font_size: ds.FONT_LABEL
                            size_hint_y: None
                            height: dp(18)
                            text_size: self.width, dp(18)
                            halign: "left"
                            valign: "middle"

                    GridLayout:
                        id: content_grid
                        cols: 2
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(24)

                        CardBox:
                            size_hint_y: None
                            height: self.minimum_height
                            padding: dp(20)
                            spacing: dp(14)
                            background_color: hx(app.theme_state.surface)
                            border_color: hx(app.theme_state.border)

                            Label:
                                text: root.form_heading
                                font_name: ds.EMOJI_FONT
                                color: hx(app.theme_state.text_primary)
                                font_size: "20sp"
                                bold: True
                                size_hint_y: None
                                height: dp(28)
                                text_size: self.width, dp(28)
                                halign: "left"
                                valign: "middle"

                            GridLayout:
                                id: form_grid
                                cols: 2
                                size_hint_y: None
                                height: self.minimum_height
                                spacing: dp(12)

                                BoxLayout:
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    spacing: dp(6)
                                    Label:
                                        text: "Nombre del cliente"
                                        color: hx(app.theme_state.text_secondary)
                                        font_size: ds.FONT_LABEL
                                        size_hint_y: None
                                        height: dp(18)
                                        text_size: self.size
                                        halign: "left"
                                        valign: "middle"
                                    AppTextInput:
                                        id: client_name_input
                                        hint_text: "Ej. Carlos Pacheco"

                                BoxLayout:
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    spacing: dp(6)
                                    BoxLayout:
                                        size_hint_y: None
                                        height: dp(18)
                                        spacing: dp(4)
                                        Label:
                                            text: "Cancha"
                                            color: hx(app.theme_state.text_secondary)
                                            font_size: ds.FONT_LABEL
                                            text_size: self.size
                                            halign: "left"
                                            valign: "middle"
                                        Label:
                                            text: "⚽"
                                            font_name: ds.EMOJI_FONT
                                            color: hx(app.theme_state.text_secondary)
                                            font_size: ds.FONT_LABEL
                                            size_hint_x: None
                                            width: dp(18)
                                            text_size: self.size
                                            halign: "center"
                                            valign: "middle"
                                    AppSpinner:
                                        id: service_spinner
                                        values: list(app.fields.keys())
                                        text: root.service_options[0]
                                        on_text: app.get_screen("reservations").on_field_selected(self.text)

                                BoxLayout:
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    spacing: dp(6)
                                    Label:
                                        text: "Fecha"
                                        color: hx(app.theme_state.text_secondary)
                                        font_size: ds.FONT_LABEL
                                        size_hint_y: None
                                        height: dp(18)
                                        text_size: self.size
                                        halign: "left"
                                        valign: "middle"
                                    AppTextInput:
                                        id: date_input
                                        hint_text: "2026-05-04"

                                BoxLayout:
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    spacing: dp(6)
                                    Label:
                                        text: "Hora inicio"
                                        color: hx(app.theme_state.text_secondary)
                                        font_size: ds.FONT_LABEL
                                        size_hint_y: None
                                        height: dp(18)
                                        text_size: self.size
                                        halign: "left"
                                        valign: "middle"
                                    AppSpinner:
                                        id: start_time_spinner
                                        values: root.start_time_options
                                        text: root.start_time_options[0]

                                BoxLayout:
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    spacing: dp(6)
                                    Label:
                                        text: "Hora fin"
                                        color: hx(app.theme_state.text_secondary)
                                        font_size: ds.FONT_LABEL
                                        size_hint_y: None
                                        height: dp(18)
                                        text_size: self.size
                                        halign: "left"
                                        valign: "middle"
                                    AppSpinner:
                                        id: end_time_spinner
                                        values: root.end_time_options
                                        text: root.end_time_options[0] if root.end_time_options else "Sin disponibilidad"

                                BoxLayout:
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    spacing: dp(6)
                                    Label:
                                        text: "Cantidad personas"
                                        color: hx(app.theme_state.text_secondary)
                                        font_size: ds.FONT_LABEL
                                        size_hint_y: None
                                        height: dp(18)
                                        text_size: self.size
                                        halign: "left"
                                        valign: "middle"
                                    AppTextInput:
                                        id: people_input
                                        hint_text: "5"
                                        input_filter: "int"

                                BoxLayout:
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    spacing: dp(6)
                                    Label:
                                        text: "Telefono"
                                        color: hx(app.theme_state.text_secondary)
                                        font_size: ds.FONT_LABEL
                                        size_hint_y: None
                                        height: dp(18)
                                        text_size: self.size
                                        halign: "left"
                                        valign: "middle"
                                    AppTextInput:
                                        id: phone_input
                                        hint_text: "3001234567"

                                BoxLayout:
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    spacing: dp(6)
                                    Label:
                                        text: "Direccion"
                                        color: hx(app.theme_state.text_secondary)
                                        font_size: ds.FONT_LABEL
                                        size_hint_y: None
                                        height: dp(18)
                                        text_size: self.size
                                        halign: "left"
                                        valign: "middle"
                                    AppTextInput:
                                        id: address_input
                                        hint_text: "Direccion autocompletada"
                                        readonly: True

                            CardBox:
                                size_hint_y: None
                                height: self.minimum_height
                                padding: dp(16)
                                spacing: dp(8)
                                background_color: hx(app.theme_state.surface_alt)
                                border_color: hx(app.theme_state.border)
                                shadow_offset: dp(0)

                                Label:
                                    text: root.quote_schedule_text
                                    color: hx(app.theme_state.primary)
                                    font_size: ds.FONT_LABEL
                                    bold: True
                                    size_hint_y: None
                                    height: dp(18)
                                    text_size: self.width, dp(18)
                                    halign: "left"
                                    valign: "middle"

                                Label:
                                    text: root.quote_total_text
                                    color: hx(app.theme_state.text_primary)
                                    font_size: "28sp"
                                    bold: True
                                    size_hint_y: None
                                    height: dp(34)
                                    text_size: self.width, dp(34)
                                    halign: "left"
                                    valign: "middle"

                                Label:
                                    text: root.quote_discount_text
                                    color: hx(app.theme_state.warning) if "0%" not in root.quote_discount_text else hx(app.theme_state.text_muted)
                                    font_size: ds.FONT_LABEL
                                    size_hint_y: None
                                    height: dp(18)
                                    text_size: self.width, dp(18)
                                    halign: "left"
                                    valign: "middle"

                                Label:
                                    text: root.quote_promotion_text
                                    color: hx(app.theme_state.text_secondary)
                                    font_size: ds.FONT_LABEL
                                    size_hint_y: None
                                    height: dp(18)
                                    text_size: self.width, dp(18)
                                    halign: "left"
                                    valign: "middle"

                                Label:
                                    text: root.quote_support_text
                                    color: hx(app.theme_state.text_muted)
                                    font_size: ds.FONT_LABEL
                                    size_hint_y: None
                                    height: self.texture_size[1]
                                    text_size: self.width, None
                                    halign: "left"
                                    valign: "top"

                                Label:
                                    text: root.availability_text
                                    color: hx(app.theme_state.success) if root.availability_color == "success" else hx(app.theme_state.danger) if root.availability_color == "danger" else hx(app.theme_state.warning) if root.availability_color == "warning" else hx(app.theme_state.text_muted)
                                    font_size: ds.FONT_LABEL
                                    bold: True
                                    size_hint_y: None
                                    height: dp(18)
                                    text_size: self.width, dp(18)
                                    halign: "left"
                                    valign: "middle"

                                Label:
                                    text: root.selected_range_text
                                    color: hx(app.theme_state.primary)
                                    font_size: ds.FONT_LABEL
                                    size_hint_y: None
                                    height: dp(18)
                                    text_size: self.width, dp(18)
                                    halign: "left"
                                    valign: "middle"

                            BoxLayout:
                                size_hint_y: None
                                height: dp(48)
                                spacing: dp(12)
                                PrimaryButton:
                                    id: save_button
                                    text: root.save_button_text
                                    busy_text: "Guardando..."
                                    on_release: root.save_reservation()
                                SecondaryButton:
                                    text: "Ver disponibilidad"
                                    on_release: root.open_calendar()
                                SecondaryButton:
                                    text: "Limpiar"
                                    on_release: root.clear_form()

                            Label:
                                text: root.save_feedback_text
                                color: hx(app.theme_state.danger) if root.save_feedback_tone == "danger" else hx(app.theme_state.warning) if root.save_feedback_tone == "warning" else hx(app.theme_state.success) if root.save_feedback_tone == "success" else hx(app.theme_state.text_muted)
                                opacity: 1 if root.save_feedback_text else 0
                                font_size: ds.FONT_LABEL
                                size_hint_y: None
                                height: self.texture_size[1] if root.save_feedback_text else 0
                                text_size: self.width, None
                                halign: "left"
                                valign: "top"

                            Widget:

                        BoxLayout:
                            id: right_column
                            orientation: "vertical"
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(14)

                            CardBox:
                                id: live_courts_card
                                size_hint_y: None
                                height: self.minimum_height
                                padding: dp(18)
                                spacing: dp(12)
                                background_color: hx(app.theme_state.surface)
                                border_color: hx(app.theme_state.primary)

                                BoxLayout:
                                    size_hint_y: None
                                    height: dp(42)
                                    spacing: dp(10)
                                    Label:
                                        text: "🏟"
                                        font_name: ds.EMOJI_FONT
                                        color: hx(app.theme_state.success)
                                        font_size: "22sp"
                                        size_hint_x: None
                                        width: dp(30)
                                        text_size: self.size
                                        halign: "center"
                                        valign: "middle"
                                    BoxLayout:
                                        orientation: "vertical"
                                        spacing: dp(1)
                                        Label:
                                            text: "Selector live de canchas"
                                            color: hx(app.theme_state.text_primary)
                                            font_size: "19sp"
                                            bold: True
                                            size_hint_y: None
                                            height: dp(22)
                                            text_size: self.width, dp(22)
                                            halign: "left"
                                            valign: "middle"
                                        Label:
                                            text: root.live_court_summary_text
                                            color: hx(app.theme_state.text_muted)
                                            font_size: ds.FONT_LABEL
                                            size_hint_y: None
                                            height: dp(18)
                                            text_size: self.width, dp(18)
                                            halign: "left"
                                            valign: "middle"
                                            shorten: True
                                            shorten_from: "right"
                                    Label:
                                        text: "EN VIVO"
                                        color: hx(app.theme_state.success)
                                        font_size: "11sp"
                                        bold: True
                                        size_hint_x: None
                                        width: dp(78)
                                        text_size: self.width, self.height
                                        halign: "right"
                                        valign: "middle"

                                GridLayout:
                                    id: live_courts_grid
                                    cols: 2
                                    size_hint_y: None
                                    height: self.minimum_height
                                    spacing: dp(10)
                                    row_default_height: dp(236)
                                    row_force_default: True

                            CardBox:
                                id: recent_reservations_card
                                size_hint_y: None
                                height: self.minimum_height
                                padding: dp(18)
                                spacing: dp(12)
                                background_color: hx(app.theme_state.surface)
                                border_color: hx(app.theme_state.border)

                                Label:
                                    text: "Partidos recientes"
                                    color: hx(app.theme_state.text_primary)
                                    font_size: "20sp"
                                    bold: True
                                    size_hint_y: None
                                    height: dp(28)
                                    text_size: self.width, dp(28)
                                    halign: "left"
                                    valign: "middle"

                                Label:
                                    text: root.summary_text
                                    color: hx(app.theme_state.text_muted)
                                    font_size: ds.FONT_LABEL
                                    size_hint_y: None
                                    height: dp(36)
                                    text_size: self.width, None
                                    halign: "left"
                                    valign: "top"

                                CardBox:
                                    size_hint_y: None
                                    height: dp(104) if not root.has_reservations else 0
                                    opacity: 0 if root.has_reservations else 1
                                    padding: dp(14)
                                    spacing: dp(6)
                                    background_color: hx(app.theme_state.surface_alt)
                                    border_color: hx(app.theme_state.border)
                                    shadow_offset: dp(0)

                                    Label:
                                        text: "Sin partidos"
                                        color: hx(app.theme_state.text_primary)
                                        font_size: "18sp"
                                        bold: True
                                        size_hint_y: None
                                        height: dp(22)
                                        text_size: self.width, dp(22)
                                        halign: "left"
                                        valign: "middle"

                                    Label:
                                        text: root.empty_state_text
                                        color: hx(app.theme_state.text_muted)
                                        font_size: ds.FONT_LABEL
                                        text_size: self.width, None
                                        halign: "left"
                                        valign: "top"

                                BoxLayout:
                                    id: reservations_list
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    spacing: dp(12)
